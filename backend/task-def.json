{
  "family": "keiei-ai-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "",
  "containerDefinitions": [
    {
      "name": "keiei-ai-backend",
      "image": "",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "/keiei-ai/DATABASE_URL"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "/keiei-ai/ANTHROPIC_API_KEY"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "/keiei-ai/OPENAI_API_KEY"
        },
        {
          "name": "TAVILY_API_KEY",
          "valueFrom": "/keiei-ai/TAVILY_API_KEY"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "/keiei-ai/SECRET_KEY"
        },
        {
          "name": "ENVIRONMENT",
          "valueFrom": "/keiei-ai/ENVIRONMENT"
        },
        {
          "name": "ALLOWED_ORIGINS",
          "valueFrom": "/keiei-ai/ALLOWED_ORIGINS"
        },
        {
          "name": "LANGCHAIN_API_KEY",
          "valueFrom": "/keiei-ai/LANGCHAIN_API_KEY"
        },
        {
          "name": "LANGCHAIN_TRACING_V2",
          "valueFrom": "/keiei-ai/LANGCHAIN_TRACING_V2"
        },
        {
          "name": "LANGCHAIN_PROJECT",
          "valueFrom": "/keiei-ai/LANGCHAIN_PROJECT"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/keiei-ai-backend",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
